{
  "name": "storyscript-syntax",
  "displayName": "StoryScript Language Support",
  "description": "Syntax highlighting and language intelligence for .StoryScript files",
  "version": "0.2.0",
  "publisher": "AnggaAryaSaputra",
  "repository": {
    "type": "git",
    "url": "https://github.com/anggaaryas/storyscript"
  },
  "license": "LGPL-2.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:storyscript"
  ],
  "main": "./out/client/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "storyscript",
        "aliases": [
          "StoryScript",
          "storyscript"
        ],
        "extensions": [
          ".StoryScript"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/storyscript-icon.png",
          "dark": "./icons/storyscript-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "storyscript",
        "scopeName": "source.storyscript",
        "path": "./syntaxes/storyscript.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b ./client/tsconfig.json && tsc -b ./server/tsconfig.json",
    "watch": "tsc -b ./client/tsconfig.json --watch & tsc -b ./server/tsconfig.json --watch",
    "package": "npm run compile && npx vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.9.0",
    "typescript": "^5.3.0"
  }
}
